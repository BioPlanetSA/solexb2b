@using SolEx.Hurt.Core
@using SolEx.Hurt.Core.BLL
@model Tuple<SolEx.Hurt.Model.Interfaces.IKlient, ProduktKlienta, Dictionary<SolEx.Hurt.Model.Enums.RabatTyp, SolEx.Hurt.Core.ModelBLL.RabatBLL>>

<div class="modal fade dokument" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true" style="text-align: left;">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info">
                <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
                <h3 class="modal-title">
                    Dla klienta: <b>@Model.Item1.Nazwa</b>
                    <br />
                    Dla produktu: <b>@Model.Item2.Nazwa</b>
                    <br />

                </h3>
            </div>
            <div class="modal-body">
                @if (@Model.Item1.PoziomCenowyId.HasValue)
                {
                    <text>ID poziomu cenowego przy sprzedaży dla tego klienta: <b> @Model.Item1.PoziomCenowyId.Value </b></text> <br/>
                    var cena = @SolexBllCalosc.PobierzInstancje.CenyPoziomy.PobierzCenyProduktu(Model.Item2.Id)[Model.Item1.PoziomCenowyId.Value];
                    <text>Cena produktu w tym poziomie netto: </text> @cena.Netto @cena.WalutaId <br />
                }
                
                Rabat z karty klienta: <b>@Model.Item1.Rabat</b> <br />

                @if (Model.Item3.Count > 0)
                {
                    <table class="table-bordered">
                        <thead>
                            <th>Typ</th>
                            <th>Dla kogo</th>
                            <th>Na co</th>
                            <th>wartość rabatu</th>
                            <th>od kiedy</th>
                            <th>do kiedy</th>
                        </thead>
                        @foreach (var item in Model.Item3)
                        {
                            <tr>
                                <td>@item.Key.ToString()</td>
                                <td>@item.Value.DlaKogo</td>
                                <td>@item.Value.NaCo</td>
                                <td>@item.Value.Wartosc1</td>
                                <td>@item.Value.OdKiedy</td>
                                <td>@item.Value.DoKiedy</td>
                            </tr>
                        }

                    </table>
                }
                else
                {
                    <text><b>Brak wpisów o rabatach</b></text>
                }
                
                <br/>
                Cena po rabatach klienta netto: <b> @Model.Item2.FlatCeny.CenaNetto</b>

            </div>
        </div>
    </div>
</div>