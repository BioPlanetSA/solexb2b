@using SolEx.Hurt.Core.BLL
@using SolEx.Hurt.Web.Site2.Helper
@model IList<SolEx.Hurt.Model.SzablonLimitow>
<table class="table table-condensed">
    <thead>
        <tr>
            <th>@Html.PobierzTlumaczenie("Nazwa")</th>
            <th>@Html.PobierzTlumaczenie("Limit ilości zamówień")</th>
            <th>@Html.PobierzTlumaczenie("Limit wartości zamówień")</th>
            <th>@Html.PobierzTlumaczenie("Limit ile miesięcy")</th>
            <th></th>
        </tr>
    </thead>
    <tfoot style="display:table-header-group">
        <tr>
            <th>
                <input type="text" class="form-control" />
            </th>
            <th>
                <input type="text" class="form-control" />
            </th>
            <th>
                <input type="text" class="form-control" />
            </th>
            <th>
                <input type="text" class="form-control" />
            </th>
        </tr>

    </tfoot>
    <tbody>
        @foreach (var y in Model)
        {
            <tr>
                <td>
                    @y.Nazwa
                </td>
                <td>
                    @y.IloscZamowien
                </td>
                <td>
                    @y.WartoscZamowien
                </td>
                <td>
                    @y.IloscMiesiecy
                </td>
                <td>
                    @Html.ActionLink(SolexBllCalosc.PobierzInstancje.Konfiguracja.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Edytuj"), "Edycja", new {id = y.Id}, new {@class = "okno-modalne btn btn-sm btn-secondary"})
                    @Html.ActionLink(SolexBllCalosc.PobierzInstancje.Konfiguracja.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Usuń"), "Usun", new { id = y.Id }, new { @class = "btn btn-danger btn-sm btn-usun" })
                    
                </td>
            </tr>
        }
    </tbody>
</table>