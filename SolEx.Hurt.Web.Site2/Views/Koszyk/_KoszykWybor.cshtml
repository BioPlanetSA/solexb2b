@using System.Globalization
@using SolEx.Hurt.Core
@using SolEx.Hurt.Core.BLL
@using SolEx.Hurt.Core.ModelBLL
@using SolEx.Hurt.Web.Site2.Helper
@model SolEx.Hurt.Web.Site2.Models.DanewyborKoszyka

@{
    var wybranyKoszyk = Model.SlownikKoszykow.First(x => x.Key == Model.IdWybranego).Value;
}

<div>
    <div class="form-inline" id="wybor-koszyka">
        <div class="wybor-koszyka btn-group">
            <button type="button" class="btn dropdown-toggle btn-sm btn-secondary" data-toggle="dropdown">
                <div class="opcje">
                    @if (Model.IdWybranego != 0)
                    {   <span class="nazwa-koszyka">
                           @wybranyKoszyk.Key
                        </span>
                        <span class="data-modyfikacji">
                            @wybranyKoszyk.Value.DataModyfikacji
                        </span>
                    }
                </div>
            </button>
            <div class="dropdown-menu" role="menu">
                @foreach (KeyValuePair<long, KeyValuePair<string, KoszykBll>> x in Model.SlownikKoszykow)
                {
                    bool wybrany = x.Key == Model.IdWybranego;
                    <a class="@Html.Raw(wybrany ? "koszyk-wybrany" : "") dropdown-item" data-pars data-aktualnastrona="1" href="@Url.Action("WybranieKoszyka", "Koszyk", new { idKoszyka  = x.Key})">
                        <span class="nazwa-koszyka">
                            @x.Value.Key
                        </span>
                        <span class="data-modyfikacji">
                            @x.Value.Value.DataModyfikacji
                        </span>
                        @if (wybrany)
                        {
                            <i class="fa fa-check"></i>
                        }
                    </a>
                }
            </div>
        </div>
        @if (Model.PokazujZarzadzanie)
        {
            <a class="btn btn-sm btn-danger usun" href="@Url.Action("UsunKoszyk", "Koszyk", new {idKoszyka = Model.IdWybranego})">@Html.PobierzTlumaczenie("Usuń")</a>
            <button type="button" class="btn btn-secondary btn-sm" data-toggle="modal" data-target="#myModal">@Html.PobierzTlumaczenie("Nowy")</button>

            <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
                <div class="modal-dialog modal-lg" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                            <h4 class="modal-title" id="myModalLabel">@Html.PobierzTlumaczenie("Utwórz nowy koszyk")</h4>
                        </div>
                        <div class="modal-body">
                            @Html.Label("nowy-nazwa", @Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id,"Nazwa koszyka"))
                            @Html.TextBox("nazwa", "", new { @class = "form-control", id = "nowy-nazwa" })
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">@Html.PobierzTlumaczenie("Anuluj")</button>
                            @{
                                string urlDodania = @Url.Action("DodajKoszyk", "Koszyk") + "?nazwa=nowy";
                            }
                           <a class="btn btn-primary dodaj" href="@urlDodania">@Html.PobierzTlumaczenie("Utwórz")</a>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>

</div>




<script language="javascript" type="text/javascript">
    $('#wybor-koszyka .usun').on('click', function (e) {
        e.preventDefault();
        PotwierdzenieAlert('#wybor-koszyka', '', '@SolexBllCalosc.PobierzInstancje.Konfiguracja.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Czy na pewno chcesz usunąc koszyk. Jest to operacja nieodwracalna.")',
            '@SolexBllCalosc.PobierzInstancje.Konfiguracja.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Tak")',
            '@SolexBllCalosc.PobierzInstancje.Konfiguracja.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id,"Nie")', function (el) {
                var a = $(el).parent().find('.usun');
                window.location.href = $(a).attr('href');

            });
    });
    $('#wybor-koszyka .dodaj').on('click', function (e) {
        e.preventDefault();
        var nazwa = $('#wybor-koszyka').parent().find('#nowy-nazwa');
        window.location.href = $('#wybor-koszyka .dodaj').attr('href').replace("nowy","") + $(nazwa).val();
    });
</script>
