    bool czySaRodziny = SolexBllCalosc.PobierzInstancje.Konfiguracja.AtrybutyRodzin.Any();
    bool czyDrzewkoProducentow = SolexBllCalosc.PobierzInstancje.DostepDane.Pobierz<GrupaBLL>(SolexHelper.AktualnyKlient, x => x.Producencka).Any();
    bool czyPokazywacCenaDetal = (SolexBllCalosc.PobierzInstancje.Konfiguracja.GetPriceLevelDetal != null);


    if (sposobyPokazywaniaStanow == false)
    {
        //mze byc tak ze ktos pokazuje belke dostepnosci dla klienta, co nie jest w sposobach stanow - dlatego Bartek dodaje na dodatkowy warunek
        if (SolexBllCalosc.PobierzInstancje.Konfiguracja.MaxPokazywanyStan > 1)
        {
            sposobyPokazywaniaStanow = true;
        }
    }

}
