@section Nazwa {
   Uniwersalny plik CSV
}
@section Szablon{@if (Model != null){List<object> obiektyDoCSV = new List<object>();
        foreach (ProduktKlienta p in Model)
        {
            dynamic obiekt = new ExpandoObject();

            obiekt.ean = p.KodKreskowy;
            obiekt.id = p.Id;
            obiekt.sku = p.Kod;
            obiekt.name = p.Nazwa;

            if (czySaRodziny)
            {
                obiekt.model = p.Rodzina;
            }

            if (czyDrzewkoProducentow)
            {
                obiekt.brand = p.MarkaNazwa;
            }

            obiekt.desc = p.Opis;
            obiekt.url = Url.ZbudujLink(p, SolexHelper.AktualnyJezyk, false);
            obiekt.photo = p.ZdjecieGlowne != null ? p.ZdjecieGlowne.LinkOryginal : "";

            obiekt.photo1 = p.Zdjecia.Count > 1 ? p.Zdjecia[1].LinkOryginal : "";
            obiekt.photo2 = p.Zdjecia.Count > 2 ? p.Zdjecia[2].LinkOryginal : "";
            obiekt.photo3 = p.Zdjecia.Count > 3 ? p.Zdjecia[3].LinkOryginal : "";

            obiekt.Kategoria = p.Kategorie.Where(x => x.Widoczna).Select(x => x.Sciezka).Join(";");
            obiekt.unit = p.JednostkaPodstawowa.Nazwa;
            obiekt.weight = p.Waga.HasValue ? p.Waga.Value.DoLadnejCyfry() : "";
            obiekt.PKWiU = p.PKWiU;

            if (sposobyPokazywaniaStanow)
            {
                obiekt.inStock = p.NaStanie;
                obiekt.qty = p.IloscOgraniczonaDoMax;
                obiekt.availability = p.DostawaData.HasValue ? p.DostawaData.Value.ToShortDateString() : null;
            }

            obiekt.requiredBox = p.WymaganeOz;
            obiekt.quantityPerBox = p.IloscWOpakowaniu.DoLadnejCyfry();
            obiekt.priceAfterDiscountNet = p.FlatCeny.CenaNetto.Wartosc.DoLadnejCyfry();
            obiekt.vat = p.Vat.DoLadnejCyfry();

            if (czyPokazywacCenaDetal)
            {
                obiekt.retailPriceGross = p.FlatCeny.CenaDetalicznaBrutto.Wartosc.DoLadnejCyfry();
            }
            

            obiektyDoCSV.Add(obiekt);
        }

        StringWriter textwriter = (new CSVHelperExt()).WygenerujCsvDlaListyObiektow(obiektyDoCSV);
        @Html.Raw(textwriter)
    }
