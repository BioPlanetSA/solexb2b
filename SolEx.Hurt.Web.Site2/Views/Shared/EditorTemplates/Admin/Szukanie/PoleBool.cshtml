    new SelectListItem() { Text = "Tak", Value = "True",Selected =szukane=="True" }, new SelectListItem() { Text = "Nie", Value = "False",Selected =szukane=="False" } }, new { @class = "form-control form-control-sm bool", form = "lista" })

