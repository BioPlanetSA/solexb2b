                @*.on('keyup', function () {
                $('#@id').closest('.pole').find('.walidator-pola-tekstowe').hide();
                })*@
        },
    });




    var element = $('#@id');

    var a = element.val();
    if (a != '') {
        $("#@(id)-edytor").show();
        $("#@(id)-checkbox").prop("checked", false);
    }

    $(document).ready(function () {
        $("#@(id)-checkbox").change(function () {
            if (this.checked) {
                $("#@(id)-edytor").hide();
                var tekst = $('#@id').val();
                $('#@(id)-checkbox').data('Opis', tekst);
                $('#@id').val('');
            } else {
                $("#@(id)-edytor").show();
                var data = $('#@(id)-checkbox').data("Opis");
                $("#@id").val(data);
            }
        });
    });

(() => {
    function enableTinyMCESourceModalFix(querySelectorPrefix) {
        function waitForElement(querySelector) {
            return new Promise(function (resolve) {
                var existingElement = document.querySelector(querySelector);
                if (existingElement) {
                    return resolve(existingElement);
                }
 
                var observer = new MutationObserver(function () {
                    var elementToWaitFor = document.querySelector(querySelector);
                    if (elementToWaitFor) {
                        resolve(elementToWaitFor);
                        observer.disconnect();
                    }
                });
 
                observer.observe(document.body, {
                    childList: true,
                    subtree: true
                });
            });
        }
 
        waitForElement(querySelectorPrefix + ' .mce-tinymce.mce-container.mce-panel')
            .then(function (elem) {
                return waitForElement(querySelectorPrefix + ' div[aria-label="Source code"]');
            })
            .then(function (sourceModal) {
                var button = sourceModal.querySelector('button');
                if (!button) return;
 
                button.addEventListener('click', function () {
                    document.body.classList.remove('modal-open');
 
                    setTimeout(() => {
                        var observer = new MutationObserver(function () {
                            var blocker = document.querySelector('.mce-modal-block');
                            if (!blocker) {
                                document.body.classList.add('modal-open');
                                observer.disconnect();
                            }
                        });
 
                        observer.observe(document.body, {
                            childList: true,
                            subtree: true
                        });
                    }, { once: true });
                }, 50)
            })
            .catch(function (error) {
                console.warn('Błąd w TinyMCE modal fix:', error);
            });
    }
 
    enableTinyMCESourceModalFix('[data-s-tinymce="@(id)"]');
})();

</script>
