@using SolEx.Hurt.Helpers
@using SolEx.Hurt.Model.Helpers
@model SolEx.Hurt.Core.DostepDane.OpisPolaObiektu

@Html.Partial("EditorTemplates/Admin/_naglowekEdytora", Model)

@if (!string.IsNullOrEmpty(Model.LinkDoDokumentacji))
{
    <a href="@Model.LinkDoDokumentacji"><i class="fa fa-question-circle" aria-hidden="true"></i></a>
}

@{
    string id = Model.IdentyfikatorObiektu + "-" + Model.NazwaPola;
    string idEdytora = string.Format("{0}-checkbox", id);
    Dictionary<string, object> pars = new Dictionary<string, object> { { "class", "form-control form-control-sm" },  { "id", id } };
    if (Model.Wymagane)
    {
        pars.Add("required","required");
    }
    pars.Add("data-identyfikatorObiektu", Model.IdentyfikatorObiektu);
    pars.Add("data-walidator",Model.WalidatorDanych!=null? Model.WalidatorDanych.PobierzOpisTypu():"");
    if (Model.PobieraneErp)
    {
     
        pars["class"] += " edytowaneErpNieWolnoEdytowac";
    }
    if (Model.PobieraneErp || Model.TylkoDoOdczytu)
    {
        pars.Add("readonly", "readonly");
    }
}

@if (!Model.Wymagane)
{
    <div class="pole pole-edytor-tekstowy" data-s-tinymce="@(id)">
        <a href="/HELP/efekty.html"><i class="fa fa-question-circle" aria-hidden="true"></i></a>
        Nie pokazuj opisu <input type="checkbox" id="@(id)-checkbox" class="checkbox-nie-pokazuj-opisu" checked data-widocznosc-edytora/>
        <div id="@(id)-edytor" style="display: none">
            @Html.TextBoxFor(x => x.Wartosc, pars)
        </div>
    </div>
}
else
{
    @Html.TextBoxFor(x => x.Wartosc, pars)
    <span style="display: none; color: red;" class="walidator-pola-tekstowe">Pole jest wymagane</span>
}


<script language="javascript" type="text/javascript">
    var id = '@id';
    $('#' + id).on('keyup', WalidujPole);
    console.log(tinymce.execCommand('mceRemoveEditor', true, id));

    tinyMCE.PluginManager.add('stylebuttons', function (editor, url) {
        ['pre', 'p', 'code', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6'].forEach(function (name) {
