           { title: 'Belka szeroka', inline: 'div', classes: 'alert alert-success' },     // styles: { display: 'inline-block', border: '1px solid #2276d2', 'border-radius': '5px', padding: '2px 5px', margin: '0 2px', color: '#2276d2' } 
           { title: 'Etykieta', inline: 'span', classes: 'label label-success' },
