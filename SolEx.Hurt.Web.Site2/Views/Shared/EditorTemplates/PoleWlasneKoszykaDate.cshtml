@using SolEx.Hurt.Core.BLL.Interfejsy
@model  SolEx.Hurt.Core.BLL.Web.DodatkowePoleKoszyka
@{
    IConfigBLL config = SolEx.Hurt.Core.BLL.SolexBllCalosc.PobierzInstancje.Konfiguracja;
}
<div class="row row-xs-center koszyk-parametr ramka-wykropkowana-dol">
    <div class="parametr-nazwa col-xs-3">
        @Html.Partial("PoleWlasneKoszykaCzescWspolna", Model) </div>

        <div class="col-xs-9">
            @{
                Dictionary<string, object> parametry = new Dictionary<string, object>();
                parametry.Add("data-modul", Model.IdModulu);
                parametry.Add("data-symbol", Model.Symbol);
                if (Model.Wymagane)
                {
                    parametry.Add("required", "required");
                }
                parametry.Add("class", "form-control datepicker");
                parametry.Add("placeholder", config.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id,"Kliknij aby wybrać datę"));
            }

            @Html.TextBoxFor(model => model.WybraneWartosciString, "", parametry)

            <script type="text/javascript">
                $(function () { // will trigger when the document is ready
                    $('.datepicker').datepicker(); //Initialise any date pickers
                });
            </script>

        </div>
    </div>