@using System.Collections
@using System.Drawing
@using System.Web.Script.Serialization
@using SolEx.Hurt.Model
@using SolEx.Hurt.Web.Site2.Helper

@*@model Tuple<int,int,   List<Tuple<string, decimal, string, string>>>*@
@{

    int ilosc = Model.Item4;
    DocumentSummary dane = Model.Item3;
    int? iloscniezaplacone = dane.Niezaplacone != null ? dane.Niezaplacone.IloscPozycji : (int?) null;
    int? iloscprzetermiowane = dane.Przeterminowane != null ? dane.Przeterminowane.IloscPozycji : (int?)null;
    ArrayList list=new ArrayList();
    foreach (var d in dane.Dane)
    {
        //omijamy zerowe obiekty
        if (d.Value.Cena <= 0)
        {
            continue;
        }

        Random rand=new Random(d.Key.GetHashCode());
        int r = rand.Next(0, 200);
        int g = rand.Next(0, 200);
        int b = rand.Next(0, 200);
        Color c = Color.FromArgb(r, g, b);
        Color c2 = Color.FromArgb(r + 20, g + 20, b + 20);


        switch (d.Key)
        {
            case "zapłacone":
                c = Color.FromArgb(0, 77, 175, 124);
                c2 = Color.FromArgb(0, 94, 193, 141);
                break;

            case "przeterminowane":
                c = Color.FromArgb(0, 226,83,49);
                c2 = Color.FromArgb(0, 229, 111, 84);
                break;

            case "niezapłacone":
                c = Color.FromArgb(0, 234,200,93);
                c2 = Color.FromArgb(0, 234, 209, 136);
                break;

            case "niezrealizowane":
                c = Color.FromArgb(0, 226,83,49);
                c2 = Color.FromArgb(0, 229, 111, 84);
                break;

            case "zrealizowane":
                c = Color.FromArgb(0, 77, 175, 124);
                c2 = Color.FromArgb(0, 94, 193, 141);
                break;
        }

        string frazaBase = "Dokumenty " + d.Key + " {0} brutto";

        string fraza = Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, frazaBase).ToString();
        list.Add(new { value = d.Value.Cena.Wartosc, label = string.Format(fraza, d.Value.Cena), color = ColorTranslator.ToHtml(c), highlight = ColorTranslator.ToHtml(c2) });
    }
    var serial = new JavaScriptSerializer();
}
<div class="dokumenty-podsumowanie kafle ">
    <div class="dokumenty-legenda kafel ">
        <div>
            @Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id,"Liczba dokumentów:")
            <span class="b">@ilosc</span>
        </div>
        @if (iloscniezaplacone > 0)
        {
            <div>
                @Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Liczba dokumentów niezapłacownych:")
                <span class="b">@iloscniezaplacone</span>
            </div>
        }
        @if (iloscprzetermiowane > 0)
        {
            <div>
                @Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Liczba dokumentów przeterminowanych:")
                <span class="b">@iloscprzetermiowane</span>
            </div>
        }
    </div>
    <canvas id="myChart" width="@Model.Item1" height="@Model.Item2" class="kafel"></canvas>
    <div id="legenda" class="dokumenty-wykres-legenda kafel"></div>
</div>
<script language="javascript" type="text/javascript">
    var ctx = document.getElementById("myChart").getContext("2d");
    var data =@Html.Raw( serial.Serialize(list));
    Chart.defaults.global.tooltipTemplate=  "<%=label%>";
    var chart = new Chart(ctx).Doughnut(data, {
        animateScale: true,
        IntegersOnly:false,

        legendTemplate : "<ul class=\"<%=name.toLowerCase()%>-legend list-unstyled\"><% for (var i=0; i<segments.length; i++){%><li><span style=\"background-color:<%=segments[i].fillColor%>\"></span><%if(segments[i].label){%> <%=segments[i].label %><%}%></li><%}%></ul>"

    });
    var legend = chart.generateLegend();
    $("#legenda").append(legend);
</script>