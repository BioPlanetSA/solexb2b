@using SolEx.Hurt.Core
@using SolEx.Hurt.Core.BLL
@using SolEx.Hurt.Model.Web
@using SolEx.Hurt.Web.Site2.Helper
@model SolEx.Hurt.Model.Helpers.FormularzZapytanieModel
    @{
        string komunikat = "";
        if (ViewBag.Blad == true)
        {
             komunikat = ViewBag.Komunikat.ToString();
        }
    }
@if (ViewBag.Blad == true)
{
    string styl = ViewBag.Rezultat ? "alert alert-success" : "alert alert-danger";
    <div id="formularzZapytanieKomunikat" class="@styl">
        @Html.PobierzTlumaczenie(komunikat)
</div>
}
else
{
    Dictionary<string, object> parametry = new Dictionary<string, object>();
    parametry.Add("autofomplete", "off");
    parametry.Add("class", "animacja  form-control");
    parametry.Add("required", "required");
    parametry.Add("placeholder", "");
    <form></form>
    <form method="POST" enctype="multipart/form-data">
        <div class="row pola">
            <div class="col-sm-12 col-md-6">
                @if (Model.PokazTytul)
                {
                    string tytul = string.IsNullOrEmpty(Model.Tytul) ? "Tytuł" : Model.Tytul;
                    <fieldset class="form-group">
                        @Html.Partial("EditorTemplates/Pola/String", new ParametryPola { klasaCSS = "form-control", Nazwa = "TytulWartosc", Typ = "String", Wymagane = true, WyswietlanaNazwa = tytul })
                    </fieldset>
                }

                @if (Model.PokazujAdresEmailNaJakiOdeslacOdpowiedz)
                {
                    <fieldset class="form-group">
                        @Html.Partial("EditorTemplates/Pola/WiadomoscEmail", new ParametryPola { klasaCSS = "form-control", Nazwa = "MailDoOdpowiedzi", Typ = "WiadomoscEmail", Wymagane = true, WyswietlanaNazwa = "Adres email na jaki zostanie odesłana wiadomość" })
                    </fieldset>
                }

                @Html.HiddenFor(m => Model.PokazujAdresEmailNaJakiOdeslacOdpowiedz)
                @Html.HiddenFor(m => Model.PokazTytul)
                @Html.HiddenFor(m => Model.DoDrugiegoOpiekuna)
                @Html.HiddenFor(m => Model.DoOpiekuna)
                @Html.HiddenFor(m => Model.DoPrzedstawiciela)
                @Html.HiddenFor(m => Model.MailDoWysylki)
                @Html.HiddenFor(m => Model.Tytul)
                @Html.HiddenFor(m => Model.Tresc)

                @if (Model.DPola != null)
                {
                    for (var i = 0; i < Model.DPola.Count; i++)
                    {
                        Model.DPola[i].NazwaJakoNameDlaPola = false;
                        Model.DPola[i].klasaCSS = "form-control";
                        <fieldset class="form-group">
                            @Html.EditorFor(x => x.DPola[i], "/Pola/" + Model.DPola[i].Typ)
                        </fieldset>
                    }
                }
            </div>

            <div class="col-sm-12 col-md-6">
                <fieldset class="form-group">
                    @Html.Partial("EditorTemplates/Pola/Text", new ParametryPola { klasaCSS = "form-control", Nazwa = "TrescWartosc", Typ = "Text", Wymagane = true, WyswietlanaNazwa = Model.Tresc })
                </fieldset>
            </div>

            <fieldset class="form-group">
                @Html.Partial("EditorTemplates/Pola/Captcha")
            </fieldset>

            <div class="col-xs-12 c" id="submit-area">
                <input type="submit" name="pola" value="@Html.PobierzTlumaczenie(SolexHelper.AktualnyJezyk.Id, "Wyślij")" class="btn btn-lg btn-success">
            </div>
        </div>
    </form>
}



