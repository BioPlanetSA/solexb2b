@model IList<SolEx.Hurt.Core.DostepDane.OpisPolaObiektu>


@for (int i = 0; i < Model.Count; i++)
{
    int i1 = i;
    <div class="col-md-3">
        <label for="pole_@(Model[i].NazwaPola)">@Model[i].NazwaWyswietlana</label>
        @Html.EditorFor(x => Model[i1], "Admin\\" + Model[i].PobierzTypEdytora())
    </div>
}
<div class="col-md-12">
<button type="submit" class="btn btn-warning">Wykonaj</button>
</div>
