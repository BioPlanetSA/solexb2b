@using SolEx.Hurt.Model
@model Tuple<HistoriaDokumentu, List<HistoriaDokumentuProdukt>,Klient>

<link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/r/bs-3.3.5/jq-2.1.4,dt-1.10.8/datatables.min.css">
@*<script type="text/javascript" src="https://cdn.datatables.net/r/bs-3.3.5/jqc-1.11.3,dt-1.10.8/datatables.min.js"></script>*@
<script>
    $(document).ready(function () {
        // Setup - add a text input to each footer cell
        $('#tabela-faktura-podglad tfoot th').each(function () {
            $(this).html('<input type="text" class="form-control"/>');
        });

        // DataTable
        var table = $('#tabela-faktura-podglad').DataTable({
            "oLanguage": {
                "sLengthMenu": "Pokaż _MENU_ wpisów",
                "sInfo": "Wszystkich wpisów _TOTAL_ (_START_ - _END_)",
                "oPaginate": {
                    "sNext": "Dalej",
                    "sPrevious": "Wstecz"
                },
            }
        });
        $('#tabela-faktura-podglad_filter').remove();
        $("#tabela-faktura-podglad_wrapper").removeClass('form-inline');
        // Apply the search
        table.columns().every(function () {
            var that = this;

            $('input', this.footer()).on('keyup change', function () {
                if (that.search() !== this.value) {
                    that
                        .search(this.value)
                        .draw();
                }
            });
        });
    });
</script>

<legend>Faktura nr @Model.Item1.NazwaDokumentu Klient: @Model.Item3.Nazwa Termmin platności: @Model.Item1.TerminPlatnosci</legend>
<table id="tabela-faktura-podglad" class="table table-striped table-hover tabela-admin table-naglowek">
    <thead>
        <tr>
            <th>Nazwa klienta</th>
            <th>Nazwa produktu</th>
            <th>Kod produktu</th>
            <th>Ilość</th>
            <th>Jednostka miary</th>
            <th>Cena netto przed rabatem</th>
            <th>Cena brutto przed rabatem</th>
            <th>Cena brutto po rabacie</th>
            <th>Wartość zakupu netto</th>
            <th>Wartość VAT</th>
            <th>Wartość zakupu brutto</th>
        </tr>
    </thead>
    <tfoot style="display: table-header-group">
        <tr>
            <th>Nazwa klienta</th>
            <th>Nazwa produktu</th>
            <th>Kod produktu</th>
            <th>Ilość</th>
            <th>Jednostka miary</th>
            <th>Cena netto przed rabatem</th>
            <th>Cena brutto przed rabatem</th>
            <th>Cena brutto po rabacie</th>
            <th>Wartość zakupu netto</th>
            <th>Wartość VAT</th>
            <th>Wartość zakupu brutto</th>
        </tr>
    </tfoot>
    <tbody>
        @foreach (var item in @Model.Item2)
        {
            <tr>
                <td> @Model.Item3.Nazwa</td>
                <td> @item.NazwaProduktu</td>
                <td> @item.KodProduktu</td>
                <td> @item.Ilosc </td>
                <td> @item.JednostkaMiary</td>
                <td> @item.CenaNetto</td>
                <td> @item.CenaBrutto</td>
                <td> @item.CenaBruttoPoRabacie</td>
                <td> @item.WartoscNetto</td>
                <td> @item.WartoscVat</td>
                <td> @item.WartoscBrutto</td>
            </tr>
        }
    </tbody>
</table>
